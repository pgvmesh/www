---
import '../styles/global.css';

const DISCORD_URL    = 'https://discord.com/invite/AUjz5RGGVu';
const MESHMAPPER_URL = 'https://pgv.meshmapper.net/';
const CONTACT_EMAIL  = 'info@pgvmesh.org';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="PGV Mesh — a community MeshCore LoRa network for eastern NC. Settings, getting started, Discord, and live coverage map." />
  <title>PGV Mesh</title>
  <link rel="canonical" href="https://pgvmesh.org/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <header class="site-header">
    <div class="inner">
      <svg class="logo-icon" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="18" cy="18" r="17" stroke="#3fb950" stroke-width="2"/>
        <circle cx="18" cy="8"  r="3" fill="#3fb950"/>
        <circle cx="8"  cy="26" r="3" fill="#3fb950"/>
        <circle cx="28" cy="26" r="3" fill="#3fb950"/>
        <line x1="18" y1="11" x2="8"  y2="23" stroke="#3fb950" stroke-width="1.5"/>
        <line x1="18" y1="11" x2="28" y2="23" stroke="#3fb950" stroke-width="1.5"/>
        <line x1="8"  y1="26" x2="28" y2="26" stroke="#3fb950" stroke-width="1.5"/>
      </svg>
      <span class="site-title"><span>PGV</span> Mesh</span>
      <nav class="site-nav">
        <a href="#start">Get Started</a>
        <a href="#settings">Settings</a>
        <a href="#volunteer">Volunteer</a>
        <a href={`mailto:${CONTACT_EMAIL}`}>Contact</a>
      </nav>
    </div>
  </header>

  <!-- Hero (full-width, outside main) -->
  <section class="hero">
    <iframe
      class="hero-map"
      src="https://pgv.meshmapper.net/embed.php?fail_grid=1&zoom=11"
      title="PGV Mesh live region map"
      loading="lazy"
      scrolling="no"
      aria-hidden="true"
      tabindex="-1"
    ></iframe>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Welcome to <span class="highlight">PGV Mesh</span></h1>
      <p>A community-built, decentralized LoRa mesh network for disaster resilience and off-grid communication. When cell towers and internet fail, the mesh keeps our community connected.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={DISCORD_URL} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
          Join our Discord
        </a>
        <a class="btn btn-secondary" href={MESHMAPPER_URL} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
          View Region Map
        </a>
      </div>
    </div>
  </section>

  <main>

    <!-- Why a mesh -->
    <section id="why">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Why a Mesh?
      </h2>
      <p style="color:var(--muted); font-size:.95rem; margin-bottom:1rem;">
        <a href="https://meshcore.io/" target="_blank" rel="noopener">MeshCore</a> nodes relay text messages radio-to-radio — no internet, cell service, or license required. Hurricanes, storms, and outages take down cell and internet exactly when people need them most. PGV Mesh is a grassroots network that <strong style="color:var(--text)">doesn't depend on any of it</strong>.
      </p>
      <div class="card-grid">
        <div class="card">
          <h3>No Single Point of Failure</h3>
          <p>No central tower, server, or provider. Every node relays for its neighbors, and solar-powered repeaters keep running through extended grid outages.</p>
        </div>
        <div class="card">
          <h3>Community Built &amp; Owned</h3>
          <p>Every repeater was placed by a volunteer. No subscription fees, no corporate gatekeeper — each new node makes the network stronger for everyone.</p>
        </div>
        <div class="card">
          <h3>Always-On Readiness</h3>
          <p>The mesh is used daily for chat and testing, so it's already proven and running when an emergency hits — not a dusty radio in a closet.</p>
        </div>
      </div>
    </section>

    <!-- Get started -->
    <section id="start">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Get Started
      </h2>
      <ol class="steps">
        <li>
          <div>
            <strong>Get a device</strong>
            <p>Any board listed in the <a href="https://flasher.meshcore.io/" target="_blank" rel="noopener">MeshCore Web Flasher</a> works — most cost $20–40.</p>
          </div>
        </li>
        <li>
          <div>
            <strong>Flash it in your browser</strong>
            <p>Plug into USB at <a href="https://flasher.meshcore.io/" target="_blank" rel="noopener">flasher.meshcore.io</a> and flash the <em>Companion</em> firmware, then pair with the MeshCore phone app over Bluetooth.</p>
          </div>
        </li>
        <li>
          <div>
            <strong>Apply our <a href="#settings">settings</a></strong>
            <p>Select the USA/Canada preset, pick a node name, and set the 3-byte path hash.</p>
          </div>
        </li>
        <li>
          <div>
            <strong>Send an advert and say hello</strong>
            <p>Tap the advert (wave) icon to announce yourself. Contacts only appear after <em>they</em> advert, so be patient. If a test message shows &ldquo;Heard 1 repeat&rdquo;, you're on the mesh — tell us on <a href={DISCORD_URL} target="_blank" rel="noopener">Discord</a>!</p>
          </div>
        </li>
      </ol>
    </section>

    <!-- Settings -->
    <section id="settings">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
        Settings
      </h2>

      <div class="settings-block">
        <div class="settings-block-title">Companion — your phone-connected node</div>
        <table>
          <tbody>
            <tr><td>Preset</td><td><code>USA/Canada (Recommended)</code> — sets 910.525&nbsp;MHz, 62.5&nbsp;kHz, SF7 for you</td></tr>
            <tr><td>Coding Rate</td><td><code>8</code></td></tr>
            <tr><td>Node Name</td><td>Your choice — whatever you'd like to go by on the network</td></tr>
            <tr><td>Path Hash</td><td><code>3-byte</code></td></tr>
          </tbody>
        </table>
      </div>

      <div class="settings-block">
        <div class="settings-block-title">Repeater — a fixed node that extends coverage</div>
        <table>
          <tbody>
            <tr><td>Preset</td><td><code>USA/Canada (Recommended)</code> — sets 910.525&nbsp;MHz, 62.5&nbsp;kHz, SF7 for you</td></tr>
            <tr><td>Coding Rate</td><td><code>8</code></td></tr>
            <tr><td>Node Name</td><td><code>pgvmesh.org &lt;area&gt;</code> — e.g. <code>pgvmesh.org Grimesland</code> or <code>pgvmesh.org NC-43</code></td></tr>
            <tr><td>Path Hash</td><td><code>3-byte</code></td></tr>
            <tr><td>Zero-Hop Advert</td><td><code>every 60 min</code></td></tr>
            <tr><td>Flood Advert</td><td><code>every 3 hours</code></td></tr>
            <tr><td>Console commands</td><td><code>set txdelay 0.3</code> &middot; <code>set direct.txdelay 0.1</code> &middot; <code>set agc.reset.interval 4</code> &middot; <code>set multi.acks 1</code> &middot; <code>set rxdelay 3</code></td></tr>
          </tbody>
        </table>
      </div>

      <p style="color:var(--muted); font-size:0.85rem; margin-top:0.75rem;">
        Repeaters advert frequently because our network is young — it helps everyone find each other. Planning a repeater? Check with us first on <a href={DISCORD_URL} target="_blank" rel="noopener">Discord</a> or at <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a> so we can coordinate placement.
      </p>
    </section>

    <!-- Emergency use -->
    <section id="emergency">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Emergencies Without Cell or Internet
      </h2>
      <p style="color:var(--muted); font-size:.95rem; margin-bottom:1rem;">
        If cellular and internet are completely down, a MeshCore companion node still sends text messages across the mesh.
      </p>
      <ol class="steps">
        <li>
          <div>
            <strong>Send a message on the public channel</strong>
            <p>State your location, the emergency, and what help you need. Keep it short — short messages relay further and more reliably.</p>
          </div>
        </li>
        <li>
          <div>
            <strong>The mesh carries it</strong>
            <p>Your message hops repeater-to-repeater across the region automatically, even if no one is in direct radio range of you.</p>
          </div>
        </li>
        <li>
          <div>
            <strong>Someone bridges to help</strong>
            <p>Community members with working power or internet — or outside the affected area — relay your report to 911 or family on your behalf.</p>
          </div>
        </li>
        <li>
          <div>
            <strong>Stay reachable</strong>
            <p>Keep your node powered and watch for replies — direct messages can coordinate help to your exact location.</p>
          </div>
        </li>
      </ol>
      <p style="color:var(--muted); font-size:0.85rem; margin-top:0.75rem;">
        ⚠️ The mesh is a community best-effort network, not a replacement for 911. If any official emergency channel is available to you, use it first.
      </p>
    </section>

    <!-- Observer -->
    <section id="observer">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        Become an Observer
      </h2>
      <p style="color:var(--muted); font-size:.92rem; margin-bottom:1rem;">
        Observers feed live mesh telemetry to <a href={MESHMAPPER_URL} target="_blank" rel="noopener">our region map</a> so everyone can see network health and coverage. Flash a spare device from the <a href="https://flasher.meshcore.io/" target="_blank" rel="noopener">Web Flasher</a>, then follow the <a href="https://wiki.meshmapper.net/mqtt-setup/" target="_blank" rel="noopener">MeshMapper observer guide</a>. Stuck? Ask on <a href={DISCORD_URL} target="_blank" rel="noopener">Discord</a>.
      </p>
    </section>

    <!-- Volunteer CTA -->
    <section id="volunteer">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        Help Us Grow the Network
      </h2>
      <p style="color:var(--muted); font-size:.95rem; margin-bottom:1rem;">
        Height is everything for radio coverage, and every repeater makes the mesh stronger. No radio experience needed.
      </p>
      <div class="card-grid">
        <div class="card">
          <h3>🛰️ Host or Donate a Repeater</h3>
          <p>A solar-powered repeater costs $30–60 in parts and runs on its own — no wiring, no internet. Build one, fund one, or host one; we'll handle setup.</p>
        </div>
        <div class="card">
          <h3>🏔️ Offer a Tall Structure</h3>
          <p>Rooftop, barn, silo, water tower, hilltop, or mast? One well-placed elevated node can cover what would take a dozen ground-level repeaters.</p>
        </div>
        <div class="card">
          <h3>📡 No Interference, No Hassle</h3>
          <p>LoRa nodes use the license-free 902–928&nbsp;MHz ISM band (FCC Part 15) — the same band as garage door openers and weather stations. Brief, very low-power transmissions won't interfere with WiFi, TV, cellular, ham radio, aviation, or public safety. A node draws less power than a nightlight.</p>
        </div>
      </div>
      <div class="cta-row" style="margin-top:1.75rem;">
        <a class="btn btn-primary" href={DISCORD_URL} target="_blank" rel="noopener">Volunteer on Discord</a>
        <a class="btn btn-secondary" href={`mailto:${CONTACT_EMAIL}`}>Email {CONTACT_EMAIL}</a>
      </div>
    </section>

    <!-- Quick Links -->
    <section id="links">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Quick Links
      </h2>
      <div class="card-grid">
        <div class="card">
          <h3>Discord</h3>
          <p>Chat with the community, get help, and stay up to date.</p>
          <br/>
          <a class="btn btn-primary" href={DISCORD_URL} target="_blank" rel="noopener">Open Discord</a>
        </div>
        <div class="card">
          <h3>Region Map</h3>
          <p>Live nodes, coverage, and signal paths across our region.</p>
          <br/>
          <a class="btn btn-secondary" href={MESHMAPPER_URL} target="_blank" rel="noopener">Open MeshMapper</a>
        </div>
        <div class="card">
          <h3>MeshCore Project</h3>
          <p>Official site, supported devices, and documentation.</p>
          <br/>
          <a class="btn btn-secondary" href="https://meshcore.io/" target="_blank" rel="noopener">meshcore.io</a>
        </div>
        <div class="card">
          <h3>Web Flasher</h3>
          <p>Flash MeshCore firmware straight from your browser.</p>
          <br/>
          <a class="btn btn-secondary" href="https://flasher.meshcore.io/" target="_blank" rel="noopener">flasher.meshcore.io</a>
        </div>
      </div>
    </section>

  </main>

  <footer>
    <p>PGV Mesh &mdash; community-run MeshCore network &mdash; <a href={DISCORD_URL} target="_blank" rel="noopener">Join Discord</a> &middot; <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
  </footer>

  <button class="scroll-top" aria-label="Scroll to top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
  <script>
    const btn = document.querySelector('.scroll-top');
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
  </script>

</body>
</html>
