---
import { Picture } from 'astro:assets';
import heroLarge from '../assets/hero/pgv-mesh-pine-node.png';

interface Props {
  alt: string;
}
const { alt } = Astro.props;
---
<section class="hero">
  <Picture
    src={heroLarge}
    alt={alt}
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    formats={['avif', 'webp']}
    loading="eager"
    class="hero-bg"
  />
  <div class="hero-content"><slot /></div>
</section>
